GCP_PROJECT_ID=your-gcp-project
GCP_BQ_DATASET_GOLD=mapear_gold
GCP_BQ_DATASET_SILVER=mapear_silver
CACHE_TTL_SEC=900

# Eixo 2 — obrigatório para /narratives/search (RAG com LLM)
# Sem esta chave (ou com o valor CHANGE_ME) o endpoint retorna 503.
# Obter em: https://console.anthropic.com
MAPEAR_LLM_API_KEY=CHANGE_ME

# Modelo de embedding da busca semântica. DEVE bater com o embedding_model
# gravado em silver_narrative_embeddings pelo job de clustering.
MAPEAR_EMBEDDINGS_MODEL=paraphrase-multilingual-mpnet-base-v2
