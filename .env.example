# =============================================================================
# Mapear-RN — Variáveis de Ambiente (Monorepo)
# Copie para .env e preencha os valores
# =============================================================================

# --- Geral ---
ENVIRONMENT=local  # local | production

# --- PostgreSQL (URL Frontier) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mapear_rn
POSTGRES_USER=mapear
POSTGRES_PASSWORD=

# --- Redis (Cache / Rate Limiter) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Data Lake (local: path, prod: GCS bucket) ---
DATA_LAKE_PATH=./data/lake
GCS_BUCKET_NAME=

# --- GCP (produção) ---
GCP_PROJECT_ID=
GCP_REGION=southamerica-east1
GOOGLE_APPLICATION_CREDENTIALS=

# --- BigQuery ---
BQ_DATASET_RAW=mapear_raw
BQ_DATASET_SILVER=mapear_silver
BQ_DATASET_GOLD=mapear_gold

# --- dbt ---
DBT_PROFILES_DIR=./dbt
DBT_TARGET=dev  # dev (DuckDB) | prod (BigQuery)

# --- RSS Scraping ---
SCRAPER_MAX_WORKERS=5
SCRAPER_DELAY_MIN=2.0
SCRAPER_DELAY_MAX=5.0
SCRAPER_USER_AGENT=MapearRSS/0.1 (+https://github.com/mapear-rss)
SCRAPER_RESPECT_ROBOTS_TXT=true

# --- Circuit Breaker ---
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT=300
CB_HALF_OPEN_REQUESTS=2

# --- NLP / Enrichment ---
# local = spaCy + transformers (dev only, heavy models)
# api   = GCP Natural Language API (production, lightweight)
# skip  = no NLP (testing pipeline flow)
ENRICHMENT_MODE=local
SPACY_MODEL=pt_core_news_lg
SENTIMENT_MODEL=nlptown/bert-base-multilingual-uncased-sentiment

# --- Notificações ---
SLACK_WEBHOOK_URL=
NOTIFY_EMAIL=

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json  # json | text
