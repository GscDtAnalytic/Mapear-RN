{
  "expectation_suite_name": "raw_articles_suite",
  "expectations": [
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": { "column": "url" }
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": { "column": "content_hash" }
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": { "column": "title" }
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": { "column": "content" }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "url" }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "content_hash" }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "title" }
    },
    {
      "expectation_type": "expect_column_values_to_be_unique",
      "kwargs": { "column": "content_hash" }
    },
    {
      "expectation_type": "expect_column_values_to_match_regex",
      "kwargs": {
        "column": "url",
        "regex": "^https?://"
      }
    },
    {
      "expectation_type": "expect_column_value_lengths_to_be_between",
      "kwargs": {
        "column": "content",
        "min_value": 100
      }
    },
    {
      "expectation_type": "expect_column_value_lengths_to_be_between",
      "kwargs": {
        "column": "content_hash",
        "min_value": 64,
        "max_value": 64
      }
    }
  ],
  "meta": {
    "great_expectations_version": "1.0.0"
  }
