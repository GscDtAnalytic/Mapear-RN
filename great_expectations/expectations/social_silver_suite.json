      "kwargs": { "column": "platform", "value_set": ["facebook", "instagram", "x", "tiktok"] }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": { "column": "source_type", "value_set": ["social"] }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": { "column": "is_rn_relevant", "value_set": [true, false] }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "scope_status",
        "value_set": ["IN_SCOPE", "OUT_OF_SCOPE", "AMBIGUOUS"]
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "sentiment_label",
        "value_set": ["FAVORABLE", "WARNING", "ALERT"]
      }
    },
