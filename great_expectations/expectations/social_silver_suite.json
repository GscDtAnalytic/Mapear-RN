      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": { "column": "sentiment_overall", "min_value": -1.0, "max_value": 1.0 }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": { "column": "confidence_score", "min_value": 0.0, "max_value": 1.0 }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": { "column": "risk_score", "min_value": 0.0, "max_value": 1.0 }
    },
